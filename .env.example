# ShipSeal currently does not require client-side environment variables.
# Do not put OpenAI, Anthropic, GitHub, or private API keys in the browser.
# Server-side GitHub App variables are for Vercel/API functions only.

# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# Use https://YOUR_DOMAIN/api/github-app/oauth-callback
# GITHUB_APP_CALLBACK_URL=
# GITHUB_APP_SLUG=
# GITHUB_APP_INSTALL_URL=

# Optional server-only Repository Intelligence enrichment.
# Keep disabled for deterministic-only operation. Never prefix these with VITE_.
SHIPSEAL_DEEP_INTELLIGENCE_ENABLED=
SHIPSEAL_DEEP_INTELLIGENCE_PROVIDER=
SHIPSEAL_DEEP_INTELLIGENCE_MODEL=
SHIPSEAL_DEEP_INTELLIGENCE_API_KEY=
# Optional OpenAI-compatible HTTPS base URL; defaults to https://api.openai.com/v1
# SHIPSEAL_DEEP_INTELLIGENCE_BASE_URL=
SHIPSEAL_DEEP_INTELLIGENCE_TIMEOUT_MS=
SHIPSEAL_DEEP_INTELLIGENCE_MAX_OUTPUT_TOKENS=
SHIPSEAL_DEEP_INTELLIGENCE_MAX_REQUEST_BYTES=
SHIPSEAL_DEEP_INTELLIGENCE_MAX_RESPONSE_BYTES=
# Optional non-secret deployment label such as preview or production.
# SHIPSEAL_DEEP_INTELLIGENCE_ENVIRONMENT=

# Optional Omega 18.1 account and private project persistence (server-only).
# PostgreSQL connection string. Never prefix with VITE_.
DATABASE_URL=
# Dedicated GitHub OAuth App credentials for ShipSeal account identity.
SHIPSEAL_ACCOUNT_GITHUB_CLIENT_ID=
SHIPSEAL_ACCOUNT_GITHUB_CLIENT_SECRET=
# Use https://YOUR_DOMAIN/api/account/callback (or the vercel dev origin locally).
SHIPSEAL_ACCOUNT_GITHUB_CALLBACK_URL=
